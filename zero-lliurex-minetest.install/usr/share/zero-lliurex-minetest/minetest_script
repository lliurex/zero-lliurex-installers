#!/bin/bash


ACTION="$1"
shift

PACKAGE_LIST=$@

case $ACTION in
	installPackage)
		#Patch seeking for relevant line. Don't using patch here 
		cd /usr/share/luanti/builtin
		awk '{print $0;if ($0 ~ /local serverlist_url/) print "\tserverlist_url=\"\""}' mainmenu/serverlistmgr.lua > /tmp/a
		mv /tmp/a mainmenu/serverlistmgr.lua
	;;
	remove)
		for ix in $PACKAGE_LIST	
		do
			apt-get remove -y $ix
			TEST=$( dpkg-query -s  $ix 2> /dev/null| grep Status | cut -d " " -f 4 )
			if [ "$TEST" == 'installed' ];then
				exit 1

			fi
		done
	;;	
esac	

